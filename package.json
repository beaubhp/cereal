{
  "name": "cereal",
  "version": "0.1.0",
  "description": "On-device meeting notes for macOS",
  "productName": "Cereal",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:native:addons": "cmake-js build -d src/native -O src/native/build",
    "build:native:transcriber-helper": "node scripts/build-transcriber-helper.mjs",
    "build:native": "npm run build:native:addons && npm run build:native:transcriber-helper",
    "rebuild:native:addons": "cmake-js rebuild -d src/native -O src/native/build",
    "rebuild:native": "npm run rebuild:native:addons && npm run build:native:transcriber-helper",
    "predev": "npm run build:native",
    "prebuild": "npm run build:native",
    "predist": "npm run build",
    "predist:dmg": "npm run build",
    "dist": "electron-builder",
    "dist:dmg": "electron-builder --mac dmg"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "cmake-js": "^8.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "node-addon-api": "^8.3.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^7.3.1"
  },
  "cmake-js": {
    "runtime": "electron",
    "runtimeVersion": "35.7.5",
    "arch": "arm64"
  }
}
